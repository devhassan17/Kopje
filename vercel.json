{
  "version": 2,
  "name": "kopje-paper-flick",
  "framework": null,
  "outputDirectory": ".",
  "functions": {
    "api/scores.js": {
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "cleanUrls": true
}
